{
    "name": "pokeapi-multiframework-lab",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "dev": "pnpm --filter './apps/*' run dev",
        "build": "pnpm --filter './apps/*' run build",
        "lint": "pnpm --filter './apps/*' run lint",
        "lint:fix": "pnpm --filter './apps/*' run lint:fix",
        "typecheck": "pnpm --filter './apps/*' run typecheck",
        "check": "pnpm --filter './apps/*' run lint && pnpm --filter './apps/*' run typecheck",
        "clean": "pnpm run --filter './apps/*' --filter './packages/*' run clean",
        "prepare": "husky"
    },
    "lint-staged": {
        "apps/api-hono/**/*.{js,ts}": "pnpm --filter ./apps/api-hono run lint:fix",
        "apps/web-next/**/*.{js,jsx,ts,tsx}": "pnpm --filter ./apps/web-next run lint:fix",
        "apps/web-nuxt/**/*.{js,ts,vue}": "pnpm --filter ./apps/web-nuxt run lint:fix",
        "apps/web-sveltekit/**/*.{js,ts,svelte}": "pnpm --filter ./apps/web-sveltekit run lint:fix",
        "apps/web-tanstack-start/**/*.{js,jsx,ts,tsx}": "pnpm --filter ./apps/web-tanstack-start run lint:fix",
        "apps/comparison-astro/**/*.{js,ts,astro}": "pnpm --filter ./apps/comparison-astro run lint:fix"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7"
    },
    "dependencies": {
        "esbuild": "^0.28.0"
    }
}
